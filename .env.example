# Copy to .env for local dev. In production, set these in Render dashboard.

# Server
NODE_ENV=development
PORT=3001

# Admin credentials (env-based, no on-disk file)
# ADMIN_USERNAME is the login username.
# ADMIN_PASSWORD_HASH is a bcrypt hash. Generate with: npm run hash-password
ADMIN_USERNAME=luckoptimizer
ADMIN_PASSWORD_HASH=$2a$10$REPLACE_WITH_OUTPUT_FROM_npm_run_hash_password

# Session signing secret (32+ random bytes hex). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_64_char_random_hex

# Supabase (monitor persistence)
# Get these from https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://ctxcznwnjliuywwucamr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key
